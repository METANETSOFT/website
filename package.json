{
  "name": "metanet-i18n",
  "version": "1.0.0",
  "description": "Metanet i18n scaffold — plain TypeScript Vite SSR app",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts --port 5553",
    "build": "npm run build:css && vite build",
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./src/styles/exact-shell.css -o ./public/exact-shell.css --minify",
    "start": "NODE_ENV=production tsx server.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "nodemailer": "^7.0.3",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
