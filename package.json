{
  "name": "metanet-i18n",
  "version": "1.0.0",
  "description": "Metanet i18n scaffold — plain TypeScript Vite SSR app",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts --port 5553",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
