# App runtime
NODE_ENV=development
PORT=5553

# Public canonical site URL
SITE_URL=http://localhost:5553

# Contact mail sender
MAIL_HOST=mail.metanetsoft.com
MAIL_PORT=587
MAIL_USERNAME=info@metanetsoft.com
MAIL_PASSWORD="change-me"
MAIL_ENCRYPTION=tls
MAIL_TLS_REJECT_UNAUTHORIZED=false
MAIL_FROM_ADDRESS=info@metanetsoft.com
MAIL_FROM_NAME="Metanetsoft"
CONTACT_TO_EMAIL=info@metanetsoft.com

# CV pool submissions inbox — the Windmill cv_pipeline cron reads this box.
CV_TO_EMAIL=user@metanetsoft.com

# Notes:
# - Dokploy usually injects PORT automatically in production.
# - In production, set NODE_ENV=production.
# - Set SITE_URL to your real domain, e.g. https://metanetsoft.com
# - Quote MAIL_PASSWORD if it contains #, spaces, or semicolons.
